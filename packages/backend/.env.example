# HSR Team Builder Backend Environment Variables

# Database Configuration (required in production)
DATABASE_URL=postgresql://username:password@host:port/database

# Redis Configuration (required in production)
REDIS_URL=redis://host:port

# JWT Configuration (required in production, do not use placeholder values)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Authentication (required in production, do not use placeholder values)
ADMIN_USERNAME=your-username-here
ADMIN_PASSWORD=your-secure-password-here

# Application Configuration
NODE_ENV=production
PORT=3001

# Production Domain for CORS
PRODUCTION_DOMAIN=https://hsr-team-builder.gilded.dev
